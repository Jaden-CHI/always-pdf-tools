{
  "manifest_version": 3,
  "name": "AlwaysPDF Tools",
  "version": "1.0.0",
  "description": "브라우저에서 바로 PDF를 편집하세요. 병합, 분할, 압축, 변환, 서명 등 모든 PDF 작업을 로컬에서 처리합니다.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AlwaysPDF Tools"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "permissions": [
    "contextMenus",
    "storage",
    "downloads"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/pages/index.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
